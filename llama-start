#!/bin/bash
set -u

DIR="$(dirname "$(realpath "$0")")"
ENV_FILE="$DIR/.env"
SLOT_CLEANER=true

usage() {
    echo "Usage: $(basename "$0") [--no-slot-cleaner] [model-name]"
    echo ""
    echo "Start llama-server with a specific model configuration."
    echo "  --no-slot-cleaner    Disable the slot-cleaner sidecar (enabled by default)"
    echo "Run without arguments to list available models."
    echo ""
    echo "BNCH = llama-bench TG (p=512, n=256, ngl=99, t=8)"
    echo "SRV  = server completion TG (256 tokens via /completion)"
    echo ""
    echo "Models:"

    rows=()
    w=4
    for f in "$DIR"/compose/*.yml; do
    [[ "$f" == *slot-cleaner* ]] && continue
        name=$(basename "$f" .yml)
        ctx=$(grep -A1 "ctx-size" "$f" 2>/dev/null | tail -1 | sed "s/.*- //;s/'//g;s/\"//g" || echo "")
        ctx="$(( ctx / 1024 ))k"
        np=$(grep -A1 " -np" "$f" 2>/dev/null | tail -1 | sed "s/.*- //;s/'//g;s/\"//g" || echo "")
        [[ -z "$np" ]] && np="auto"
        mtp="N"
        fa="Y"
        if grep -qE "draft-mtp|multi-token-prediction|mtp:n_max" "$f" 2>/dev/null; then mtp="Y"; fi

        bf="$DIR/benchmark/results/$name.json"
        tg="-"
        if [[ -f "$bf" ]]; then
            tg=$(timeout 3 python3 "$DIR/benchmark/read_bench.py" "$bf" 2>/dev/null | cut -d" " -f1 || echo "-")
            tg="${tg:--}"
        fi

        cf="$DIR/benchmark/results/$name.completion.json"
        srv="-"
        if [[ -f "$cf" ]]; then
            srv=$(timeout 3 python3 "$DIR/benchmark/read_completion.py" "$cf" 2>/dev/null || echo "-")
            srv="${srv:--}"
        fi

        # shellcheck disable=SC2001
        size=$(echo "$name" | sed 's/.*-\([0-9]*\)b.*/\1/')
        srv_n=0
        [[ "$srv" != "-" ]] && srv_n=$srv
        rows+=("$size	$srv_n	$name	$ctx	$np	$fa	$mtp	$tg	$srv")
        nlen=${#name}
        [[ $nlen -gt $w ]] && w=$nlen
    done

    name_fmt="%-${w}s"

    printf "  $name_fmt %-6s %-3s %-3s %-4s %-6s %s\\n" "NAME" "CTX" "NP" "FA" "MTP" "BNCH" "SRV"
    printf "  $name_fmt %-6s %-3s %-3s %-4s %-6s %s\\n" "----" "---" "--" "--" "---" "----" "---"

    printf '%s\n' "${rows[@]}" | sort -t$'\t' -k1,1rn -k2,2rn | while IFS=$'\t' read -r _ _ name ctx np fa mtp tg srv; do
        printf "  $name_fmt %-6s %-3s %-3s %-4s %-6s %s\\n" "$name" "$ctx" "$np" "$fa" "$mtp" "$tg" "$srv"
    done
}

VER=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null || true)
nvidia-smi -pm 1 >/dev/null 2>&1 || true
if [[ -n "$VER" ]]; then
    echo "NVIDIA_DRIVER_VER=${VER}" > "$ENV_FILE"
fi

if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    usage
    exit 0
fi

if [[ "${1:-}" == "--no-slot-cleaner" ]]; then
    SLOT_CLEANER=false
    shift
fi

if [[ "${1:-}" == "--slot-cleaner" ]]; then
    echo "NOTE: --slot-cleaner is now the default; use --no-slot-cleaner to disable"
    shift
fi

if [[ $# -eq 0 ]]; then
    echo "Error: no model name provided."
    usage
    exit 1
fi

set -euo pipefail
COMPOSE="$DIR/compose/$1.yml"

if [[ ! -f "$COMPOSE" ]]; then
    echo "Available models:"
    usage
    exit 1
fi

echo "stopping current llama-server ..."
docker compose -f "$COMPOSE" down 2>/dev/null || true
docker rm -f slot-cleaner 2>/dev/null || true

echo "starting with $1 ..."
if [ "$SLOT_CLEANER" = "true" ]; then
  docker compose -f "$COMPOSE" -f "$DIR/slot-cleaner/compose.slot-cleaner.yml" --profile clean up -d
else
  docker compose -f "$COMPOSE" up -d
fi

echo "waiting for health ..."
for ((i=1; i<=150; i++)); do
    sleep 2
    status=$(docker inspect llama-server --format "{{.State.Health.Status}}" 2>/dev/null || echo "")
    if [[ "$status" == "healthy" ]]; then
        echo "llama-server is healthy (model: $1)"
        exit 0
    fi
done

echo "WARNING: health check did not become healthy within 5m"
docker ps --filter name=llama --format "{{.Names}} {{.Status}}"
exit 1
